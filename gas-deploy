#!/bin/bash
# gas-deploy: Deploy any HTML file to Google Apps Script as a web app
set -e

VERSION="1.1.0"
CONFIG_FILE="$(pwd)/.gas-deploy.json"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; BLUE='\033[0;34m'; NC='\033[0m'
info()  { echo -e "${BLUE}→${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}!${NC} $1"; }
err()   { echo -e "${RED}✗${NC} $1" >&2; }

check_env() {
  if ! command -v node &>/dev/null; then
    if command -v brew &>/dev/null; then info "Installing Node.js..."; brew install node
    else err "Please install Node.js: https://nodejs.org/"; exit 1; fi
  fi
  if ! command -v clasp &>/dev/null; then info "Installing clasp..."; npm install -g @google/clasp; fi
  if [ ! -f "$HOME/.clasprc.json" ]; then warn "Not logged in"; clasp login; fi
}

get_app_config() {
  local html_file="$1"
  python3 -c "
import json, sys, os
with open('$CONFIG_FILE') as f:
    data = json.load(f)
apps = data.get('apps', {})
# Try exact match first, then resolve to relative path
key = '$html_file'
app = apps.get(key)
if not app:
    try:
        rel = os.path.relpath(key)
        app = apps.get(rel)
    except: pass
if not app: sys.exit(1)
for k, v in app.items():
    print(f\"{k}='{v}'\")
" 2>/dev/null
}

cmd_init() {
  local html_file="" title="" access="DOMAIN"
  while [[ $# -gt 0 ]]; do
    case $1 in --title) title="$2"; shift 2 ;; --access) access="$2"; shift 2 ;; -*) err "Unknown: $1"; exit 1 ;; *) html_file="$1"; shift ;; esac
  done
  [ -z "$html_file" ] && { err "Usage: gas-deploy init <html> --title \"Title\""; exit 1; }
  [ ! -f "$html_file" ] && { err "Not found: $html_file"; exit 1; }
  [ -z "$title" ] && title=$(basename "$html_file" .html)

  local basename=$(basename "$html_file" .html)
  local gas_dir="/tmp/gas-deploy-${basename}"
  local orig_dir="$(pwd)"

  echo -e "\n${BLUE}gas-deploy${NC} v${VERSION}\nInitializing ${GREEN}${html_file}${NC} as \"${title}\"\n"
  check_env

  info "Creating Apps Script project..."
  mkdir -p "$gas_dir" && cd "$gas_dir"
  clasp create --title "$title" --type standalone 2>&1 | head -3
  local script_id=$(python3 -c "import json; print(json.load(open('.clasp.json'))['scriptId'])")
  [ -z "$script_id" ] && { err "Failed"; exit 1; }
  ok "Project: $script_id"

  cat > Code.gs << GSEOF
function doGet() {
  return HtmlService.createHtmlOutputFromFile('${basename}')
    .setTitle('${title}')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1.0')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}
GSEOF
  cat > appsscript.json << JEOF
{"timeZone":"Asia/Tokyo","dependencies":{},"webapp":{"executeAs":"USER_DEPLOYING","access":"${access}"},"exceptionLogging":"STACKDRIVER","runtimeVersion":"V8"}
JEOF

  cp "${orig_dir}/${html_file}" "${basename}.html"
  clasp push --force 2>&1 | head -5
  local deploy_id=$(clasp deploy --description "v1" 2>&1 | grep -o 'AKfycb[a-zA-Z0-9_-]*')
  [ -z "$deploy_id" ] && { err "Deploy failed"; exit 1; }
  ok "Deployed: $deploy_id"

  cd "$orig_dir"
  python3 -c "
import json, os
f = '$CONFIG_FILE'
data = json.load(open(f)) if os.path.exists(f) else {'apps':{}}
data['apps']['$html_file'] = {'script_id':'$script_id','deploy_id':'$deploy_id','title':'$title','access':'$access','gas_dir':'$gas_dir'}
json.dump(data, open(f,'w'), ensure_ascii=False, indent=2)
"
  ok "Saved to .gas-deploy.json"

  local url="https://script.google.com/macros/s/${deploy_id}/exec"
  local editor="https://script.google.com/d/${script_id}/edit"
  echo ""
  echo -e "${GREEN}デプロイ完了${NC}"
  echo ""
  echo -e "  URL:        ${BLUE}${url}${NC}"
  echo -e "  エディタ:   ${BLUE}${editor}${NC}"
  echo ""
  if [ "$access" = "DOMAIN" ]; then
    echo -e "${YELLOW}次のステップ: 権限設定${NC}"
    echo "  初回デプロイ後、Apps Scriptエディタで権限を設定してください:"
    echo "  1. 上記エディタURLを開く"
    echo "  2. 「デプロイ」→「デプロイを管理」"
    echo "  3. 編集（鉛筆アイコン）→「アクセスできるユーザー」を確認"
    echo "  4.「次のユーザーとして実行」→「自分」を選択"
    echo ""
  fi
}

cmd_push() {
  local html_file="$1"
  [ -z "$html_file" ] && { err "Usage: gas-deploy push <html>"; exit 1; }
  [ ! -f "$html_file" ] && { err "Not found: $html_file"; exit 1; }

  local app_config=$(get_app_config "$html_file")
  [ $? -ne 0 ] && { err "Not configured. Run: gas-deploy init $html_file"; exit 1; }
  eval "$app_config"

  local basename=$(basename "$html_file" .html)
  echo -e "${BLUE}gas-deploy${NC} push ${GREEN}${html_file}${NC}"

  mkdir -p "$gas_dir"
  [ -f "$gas_dir/.clasp.json" ] || echo "{\"scriptId\":\"$script_id\",\"rootDir\":\"$gas_dir\"}" > "$gas_dir/.clasp.json"
  [ -f "$gas_dir/appsscript.json" ] || echo "{\"timeZone\":\"Asia/Tokyo\",\"dependencies\":{},\"webapp\":{\"executeAs\":\"USER_DEPLOYING\",\"access\":\"$access\"},\"exceptionLogging\":\"STACKDRIVER\",\"runtimeVersion\":\"V8\"}" > "$gas_dir/appsscript.json"
  [ -f "$gas_dir/Code.gs" ] || cat > "$gas_dir/Code.gs" << GSEOF
function doGet() {
  return HtmlService.createHtmlOutputFromFile('${basename}')
    .setTitle('${title}')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1.0')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}
GSEOF

  cp "$html_file" "$gas_dir/${basename}.html"
  cd "$gas_dir"
  info "Pushing..."
  clasp push --force 2>&1 | head -5
  info "Deploying..."
  clasp deploy --deploymentId "$deploy_id" --description "auto $(date +%Y%m%d-%H%M)" 2>&1 | head -3
  cd - > /dev/null
  echo ""
  ok "更新完了 → ${BLUE}https://script.google.com/macros/s/${deploy_id}/exec${NC}"
}

cmd_list() {
  local check=false
  [ "${1:-}" = "--check" ] && check=true
  [ ! -f "$CONFIG_FILE" ] && { info "登録済みアプリなし。gas-deploy init で追加"; exit 0; }

  if $check; then
    echo -e "${BLUE}gas-deploy${NC} アプリ一覧（ヘルスチェック中...）\n"
  else
    echo -e "${BLUE}gas-deploy${NC} アプリ一覧\n"
  fi

  python3 -c "
import json, subprocess, sys
check = $([[ $check == true ]] && echo 'True' || echo 'False')
with open('$CONFIG_FILE') as f:
    data = json.load(f)
for name, app in data.get('apps', {}).items():
    url = f'https://script.google.com/macros/s/{app.get(\"deploy_id\",\"\")}/exec'
    access = app.get('access', 'DOMAIN')
    access_label = '組織内' if access == 'DOMAIN' else '一般公開'
    status = ''
    if check:
        try:
            r = subprocess.run(['curl', '-sI', '-o', '/dev/null', '-w', '%{http_code}', '-m', '5', url],
                               capture_output=True, text=True, timeout=10)
            code = r.stdout.strip()
            if code in ('200', '302'):
                status = '\033[0;32m● 稼働中\033[0m'
            elif code == '403':
                status = '\033[0;33m● 要認証\033[0m'
            else:
                status = f'\033[0;31m● エラー ({code})\033[0m'
        except:
            status = '\033[0;31m● 接続失敗\033[0m'

    print(f'  {app.get(\"title\", name)}')
    print(f'    ファイル:  {name}')
    print(f'    アクセス:  {access_label}')
    print(f'    URL:       {url}')
    if status:
        print(f'    ステータス: {status}')
    print()
"
}

cmd_open() {
  local html_file="$1"
  [ -z "$html_file" ] && { err "Usage: gas-deploy open <html>"; exit 1; }
  local app_config=$(get_app_config "$html_file")
  [ $? -ne 0 ] && { err "Not configured"; exit 1; }
  eval "$app_config"
  open "https://script.google.com/macros/s/${deploy_id}/exec" 2>/dev/null || echo "https://script.google.com/macros/s/${deploy_id}/exec"
}

case "${1:-}" in
  init)  shift; cmd_init "$@" ;;
  push)  shift; cmd_push "$@" ;;
  list)  shift; cmd_list "$@" ;;
  open)  shift; cmd_open "$@" ;;
  -v|--version) echo "gas-deploy v${VERSION}" ;;
  *)
    echo "gas-deploy v${VERSION} — HTMLをApps ScriptのWebアプリとしてデプロイ"
    echo ""
    echo "  gas-deploy init <html> --title \"タイトル\"   初期化＋初回デプロイ"
    echo "  gas-deploy push <html>                       更新（URL固定）"
    echo "  gas-deploy list                              登録済みアプリ一覧"
    echo "  gas-deploy list --check                      一覧＋ヘルスチェック"
    echo "  gas-deploy open <html>                       ブラウザで開く"
    ;;
esac
